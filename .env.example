# ============================================================================
# 环境变量样例 —— 复制为 .env 并按需填值：  cp .env.example .env
# 字段与 config.py:Settings 对齐；docker compose 会自动读取本目录 .env
# 用于 ${...} 变量插值（POSTGRES_PASSWORD / GRAFANA_PASSWORD）。
# ============================================================================

# ---- LLM（阿里百炼 DashScope）-------------------------------------------------
# 必填。DashScope API Key，同时用于 MCP 鉴权（config.Settings.api_key）。
DASHSCOPE_API_KEY=your-dashscope-api-key-here
# 对话模型名。
MODEL_NAME=qwen3-max
# 采样温度（0~1，越高越发散）。
TEMPERATURE=0.7
# 单次生成最大 token 数（可选，默认 8192）。
MAX_TOKENS=8192

# ---- Redis ------------------------------------------------------------------
# Celery broker(db0)/result(db1) 与 Pub-Sub(db5) 的基址（不带 db 后缀）。
# 宿主直跑(make dev) 用 localhost；docker compose 内由 environment 覆盖为 redis://redis:6379。
REDIS_URL=redis://localhost:6379

# ---- PostgreSQL -------------------------------------------------------------
# 异步连接串（SQLAlchemy + asyncpg）。宿主用 localhost；
# docker compose 内由 environment 覆盖为 @postgres 主机名。
DATABASE_URL=postgresql+asyncpg://travel:securepassword@localhost/travel_agent
# postgres 容器初始化用的库密码；须与 DATABASE_URL 中的密码一致。
POSTGRES_PASSWORD=securepassword

# ---- 高德地图 MCP ------------------------------------------------------------
# 默认走 DashScope 托管的 amap-maps MCP（用 DASHSCOPE_API_KEY 鉴权，有免费日配额）。
MCP_URL=https://dashscope.aliyuncs.com/api/v1/mcps/amap-maps/mcp
MCP_TRANSPORT=streamable_http
# 用自己的高德 Key（避开 DashScope 托管 MCP 的免费日配额限制 USER_DAILY_QUERY_OVER_LIMIT）：
# 在 https://console.amap.com 申请「Web服务」Key，填到下面一行（**填了就自动改连高德官方 MCP**）。
# 留空则继续用上面的 DashScope 托管 MCP。
AMAP_API_KEY=
# 高德官方 MCP 地址（一般不用改）。
AMAP_MCP_URL=https://mcp.amap.com/mcp

# ---- LangSmith 追踪（可选）---------------------------------------------------
# 是否开启 LangSmith 链路追踪。
LANGCHAIN_TRACING_V2=true
# LangSmith 项目名。
LANGCHAIN_PROJECT=travel-agent-v1
# LangSmith API Key（开启追踪时必填，否则可留占位）。
LANGCHAIN_API_KEY=your-langsmith-api-key-here

# ---- API 限流 ---------------------------------------------------------------
# 每客户端每分钟最大请求数（RateLimitMiddleware）。
RATE_LIMIT_PER_MINUTE=10

# ---- Streamlit → FastAPI -----------------------------------------------------
# Streamlit（瘦客户端）访问 FastAPI 的基址。宿主直跑用 localhost；
# docker compose 内由 streamlit 服务的 environment 覆盖为 http://api:8000。
API_BASE_URL=http://localhost:8000

# ---- LangGraph 检查点 TTL ----------------------------------------------------
# HITL/多轮会话检查点（redis db0）的存活分钟数，到期自动回收，避免无限增长。
CHECKPOINT_TTL_MINUTES=1440

# ---- Sentry（可选）----------------------------------------------------------
# 错误追踪 DSN；留空则不启用 Sentry（无额外开销）。
SENTRY_DSN=

# ---- Grafana ----------------------------------------------------------------
# Grafana 管理员(admin)初始密码（docker compose 注入 GF_SECURITY_ADMIN_PASSWORD）。
GRAFANA_PASSWORD=admin

# ---- 演示准入管理 -----------------------------------------------------------
# 管理员密码：在 Streamlit URL 加 ?admin=1 后，输入此密码进入管理面板。
# 同时作为 /admin/* 接口的 x-admin-password Header 鉴权。
ADMIN_PASSWORD=your-admin-password-here
